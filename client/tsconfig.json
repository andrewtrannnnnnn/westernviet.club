{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023", "dom", "dom.iterable"],
    "module": "esnext",
    "skipLibCheck": true,
    "noEmit": true,

    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",

    "strict": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["vite.config.ts", "src"]
}
