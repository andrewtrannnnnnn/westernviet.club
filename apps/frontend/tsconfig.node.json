{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true,

    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "strict": true,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["vite.config.ts"]
}
