{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023", "dom", "dom.iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "noEmit": true,

    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",

    "strict": true,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["vite-env-override.d.ts", "src"]
}
